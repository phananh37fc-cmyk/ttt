function filterCards() {
    var searchInput = document.getElementById('searchInput');
    var keyword = searchInput ? searchInput.value.toLowerCase().trim() : '';
    
    currentFilteredCards = data.filter(i => {
        let passCat = false;
        if (currentCat === 'All') passCat = true;
        else if (currentCat === 'listening') passCat = (i.type === 'new');
        else if (currentCat === 'starred') passCat = starredCards.includes(i.id);
        else if (currentCat === 'Từ mới' && i.type === 'new') passCat = true;
        else if (currentCat === 'Luyện dịch' && i.type === 'translate') passCat = true;
        else if (currentCat === 'Luyện tập' && i.type === 'practice') passCat = true;
        else if (i.type === currentCat) passCat = true;

        let passLes = false;
        if (currentLes === 'All' || currentLes === 'all') passLes = true;
        else if (i.lesson === currentLes) passLes = true;

        let passKey = true;
        if (keyword !== '') {
            passKey = ((i.vn && i.vn.toLowerCase().includes(keyword)) || 
                       (i.kr && i.kr.toLowerCase().includes(keyword)));
        }

        return passCat && passLes && passKey;
    });

    // Reset về trang 1 mỗi khi đổi bộ lọc, tránh lỗi trang trống
    currentPage = 1;
    displayPage();
    
