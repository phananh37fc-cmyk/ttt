    try {
        // Lệnh nhốt AI vào khuôn mẫu "Bổ luống" chi tiết nhất
        const systemPrompt = `Bạn là Gia sư Tiếng Hàn cao cấp. Hãy phân tích câu tiếng Hàn sau một cách thật chi tiết.
        BẮT BUỘC tuân thủ chặt chẽ cấu trúc sau (không tự ý thêm bớt):
        
        🎯 [Câu gốc]: <Viết lại câu>
        
        🧩 [Phân tích]:
        - Từ vựng 1 (nghĩa)
        - Trợ từ / Ngữ pháp (giải thích chức năng)
        - Cụm động từ -> Cách chia
        (Phân tích toàn bộ các thành phần trong câu theo từng gạch đầu dòng)
        
        💡 [Dịch nghĩa]: <Câu dịch tiếng Việt mượt mà>
        
        Câu cần phân tích là: `;
        
        const finalPrompt = systemPrompt + message;
        const response = await fetch("https://text.pollinations.ai/" + encodeURIComponent(finalPrompt));

        if (!response.ok) throw new Error("Server AI bận");

        const aiResponse = await response.text();
        updateMessage(typingId, formatAIResponse(aiResponse));

    } catch (error) {
        updateMessage(typingId, "⚠️ <i>Hệ thống AI đang quá tải nhẹ, bạn đợi 3 giây rồi gửi lại giúp mình nhé!</i>");
    }
}

function appendMessage(text, className) {
    const msgContainer = document.getElementById("ai-chat-messages");
    const msgDiv = document.createElement("div");
    msgDiv.className = className;
    msgDiv.innerHTML = text; 
    
    const id = "msg-" + Date.now(); 
    msgDiv.id = id;
    
    msgContainer.appendChild(msgDiv);
    msgContainer.scrollTop = msgContainer.scrollHeight; 
    return id;
}

function updateMessage(id, text) {
    const msgDiv = document.getElementById(id);
    if (msgDiv) {
        msgDiv.innerHTML = text;
        const msgContainer = document.getElementById("ai-chat-messages");
        msgContainer.scrollTop = msgContainer.scrollHeight;
    }
}

function formatAIResponse(text) {
    // Thuật toán định dạng văn bản: bôi đậm, xuống dòng, nhận diện gạch đầu dòng
    let formatted = text
        .replace(/\n/g, '<br>') // Xuống dòng
        .replace(/\*\*(.*?)\*\*/g, '<b style="color:var(--topik-blue, #0056b3);">$1</b>') // Bôi đậm có màu xanh
        .replace(/🎯/g, '<br>🎯 <b style="font-size:1.05em;">')
        .replace(/🧩/g, '<br><hr style="border-top:1px dashed #ccc; margin:10px 0;">🧩 <b style="font-size:1.05em;">')
        .replace(/💡/g, '<br><hr style="border-top:1px dashed #ccc; margin:10px 0;">💡 <b style="font-size:1.05em;">')
        .replace(/\[Câu gốc\]:|\[Phân tích\]:|\[Dịch nghĩa\]:/g, match => match + '</b>')
        .replace(/- (.*?)(?=<br>|$)/g, '<li style="margin-left: 10px;">$1</li>'); // Chuyển dấu gạch ngang thành list chấm bi

    // Dọn dẹp các thẻ list bị thừa
    formatted = formatted.replace(/(<br>)*<li/g, '<li');
    return formatted;
}

// ==========================================
// HÀM XỬ LÝ ĐÁNH DẤU TỪ KHÓ (NGÔI SAO)
// ==========================================
function toggleStar(id, event) {
    if (event) event.stopPropagation(); // Ngăn việc lật thẻ khi bấm vào ngôi sao

    // Kiểm tra xem từ này đã có trong danh sách Từ khó chưa
    let index = starredCards.indexOf(id);
    
    if (index > -1) {
        // Nếu ĐÃ CÓ -> Xóa khỏi danh sách từ khó
        starredCards.splice(index, 1);
        if (event && event.target) event.target.classList.remove('active');
    } else {
        // Nếu CHƯA CÓ -> Thêm vào danh sách từ khó
        starredCards.push(id);
        if (event && event.target) event.target.classList.add('active');
    }

    // Lưu danh sách cập nhật vào bộ nhớ trình duyệt (để F5 không bị mất)
    localStorage.setItem('myStarredCards', JSON.stringify(starredCards));

    // Nếu bạn đang đứng sẵn ở trong mục "Từ khó" mà lỡ tay bỏ sao, thì ẩn luôn thẻ đó đi
    if (currentCat === 'starred') {
        filterCards();
    }
}
</script>

