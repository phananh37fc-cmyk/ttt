/* =========================================
   GIAO DIỆN HỎI ĐÁP AI CHATBOT (BẢN PRO)
   ========================================= */
#ai-chat-widget {
    position: fixed; bottom: 20px; right: 20px;
    width: 360px; background: #fff;
    border-radius: 16px; box-shadow: 0 8px 30px rgba(0,0,0,0.15);
    z-index: 9999; overflow: hidden;
    display: flex; flex-direction: column;
    border: 1px solid rgba(0,0,0,0.1);
    transform: translateY(120%); opacity: 0; pointer-events: none;
    transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
}
#ai-chat-widget.open {
    transform: translateY(0); opacity: 1; pointer-events: auto;
}
#ai-chat-header {
    background: linear-gradient(135deg, var(--topik-blue, #0056b3), #007bff);
    color: white; padding: 15px; font-weight: bold; 
    display: flex; justify-content: space-between; align-items: center;
    cursor: pointer; font-size: 1.1rem; box-shadow: 0 2px 5px rgba(0,0,0,0.1);
}
.chat-btn-action {
    background: rgba(255,255,255,0.2); padding: 4px 10px; 
    border-radius: 20px; font-size: 0.8rem; cursor: pointer; transition: 0.2s;
}
.chat-btn-action:hover { background: rgba(255,255,255,0.4); }
#ai-chat-body { display: flex; flex-direction: column; height: 420px; }
#ai-chat-messages {
    flex: 1; padding: 15px; overflow-y: auto; background: #f4f7f6; 
    display: flex; flex-direction: column; gap: 12px; scroll-behavior: smooth;
}
/* Tùy chỉnh thanh cuộn (Scrollbar) */
#ai-chat-messages::-webkit-scrollbar { width: 6px; }
#ai-chat-messages::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }

.ai-msg, .user-msg {
    max-width: 85%; padding: 12px 15px; border-radius: 15px;
    font-size: 0.95rem; line-height: 1.5; word-wrap: break-word;
    box-shadow: 0 1px 2px rgba(0,0,0,0.05); animation: fadeInMsg 0.3s ease-out;
}
@keyframes fadeInMsg { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

.ai-msg { align-self: flex-start; background: #fff; color: #333; border-bottom-left-radius: 4px; border: 1px solid #e2e8f0; }
.user-msg { align-self: flex-end; background: var(--topik-blue, #0056b3); color: white; border-bottom-right-radius: 4px; }

#ai-chat-input-area {
    display: flex; padding: 12px; border-top: 1px solid #e2e8f0; background: #fff; gap: 8px;
}
#ai-input {
    flex: 1; padding: 10px 15px; border: 1px solid #e2e8f0; background: #f8fafc;
    border-radius: 25px; outline: none; font-size: 0.95rem; transition: 0.3s;
}
#ai-input:focus { border-color: #007bff; background: #fff; box-shadow: 0 0 0 3px rgba(0,123,255,0.1); }
#ai-chat-input-area button {
    background: var(--topik-blue, #0056b3); color: white; border: none;
    width: 42px; height: 42px; border-radius: 50%; display: flex;
    align-items: center; justify-content: center; cursor: pointer; transition: 0.2s;
}
#ai-chat-input-area button:hover { transform: scale(1.05); }

/* Hiệu ứng gõ phím (Typing Indicator) */
.typing-indicator { display: flex; gap: 4px; padding: 5px 2px; align-items: center; }
.typing-indicator span { width: 6px; height: 6px; background: #94a3b8; border-radius: 50%; animation: typingBlink 1.4s infinite; }
.typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
.typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
@keyframes typingBlink { 0%, 100% { opacity: 0.2; transform: translateY(0); } 50% { opacity: 1; transform: translateY(-3px); } }

/* Nút gọi AI nổi bên ngoài */
#ai-fab-btn {
    position: fixed; bottom: 20px; right: 20px; width: 60px; height: 60px;
    background: linear-gradient(135deg, #0056b3, #007bff); border-radius: 50%;
    box-shadow: 0 5px 15px rgba(0,123,255,0.4); display: flex; justify-content: center;
    align-items: center; font-size: 1.8rem; cursor: pointer; z-index: 9998;
    transition: 0.3s; color: white;
}
#ai-fab-btn:hover { transform: scale(1.1); }
#ai-fab-btn.hidden { display: none; }

/* Dark Mode */
body.dark-mode #ai-chat-widget { background: #1e1e1e; border-color: #333; }
body.dark-mode #ai-chat-messages { background: #121212; }
body.dark-mode .ai-msg { background: #2d2d2d; color: #e0e0e0; border-color: #444; }
body.dark-mode #ai-chat-input-area { background: #1e1e1e; border-color: #333; }
body.dark-mode #ai-input { background: #2d2d2d; color: #fff; border-color: #444; }
body.dark-mode #ai-chat-header { background: linear-gradient(135deg, #2d2d2d, #444); }

@media (max-width: 500px) {
    #ai-chat-widget { bottom: 0; right: 0; width: 100%; border-radius: 20px 20px 0 0; height: 85vh; }
    #ai-chat-body { height: calc(85vh - 60px); }
}
