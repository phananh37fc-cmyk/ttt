        if (!SpeechRecognition) {
            alert("Trình duyệt không hỗ trợ. Hãy dùng Google Chrome nhé!");
            return;
        }

        const recognition = new SpeechRecognition();
        recognition.lang = 'ko-KR'; // Cài đặt ngôn ngữ nghe là tiếng Hàn
        recognition.start(); // Bắt đầu nghe

        // Báo hiệu đang nghe
        let originalText = event.target.innerText;
        event.target.innerText = "⏳"; 

        recognition.onresult = function(e) {
            event.target.innerText = originalText; // Trả lại icon mic
            const speechToText = e.results[0][0].transcript;
            
            // Xóa khoảng trắng để so sánh dễ đúng hơn
            const cleanUserSpeech = speechToText.replace(/[\s.,?!~()]/g, '');
            const cleanCorrectText = correctText.replace(/[\s.,?!~()]/g, '');

            if (cleanUserSpeech === cleanCorrectText) {
                alert("Bạn đọc là: " + speechToText + "\n\n🎉 CHUẨN QUÁ!");
            } else {
                alert("Bạn đọc là: " + speechToText + "\n\n❌ Gần đúng rồi, nghe loa đọc lại nhé. Đáp án đúng: " + correctText);
            }
        };

       recognition.onerror = function(e) {
            event.target.innerText = originalText; // Trả lại icon mic
            
            if (e.error === 'aborted') {
                // Lỗi này hay xảy ra do chạy file offline, ta bỏ qua không hiện thông báo
                console.log("Đã hủy thu âm.");
            } else if (e.error === 'not-allowed') {
                alert("Bạn chưa cấp quyền Micro! Hãy nhấn 'Cho phép' trên góc trái trình duyệt nhé.");
            } else {
                alert("Có lỗi thu âm: " + e.error);
            }
        };
    }
