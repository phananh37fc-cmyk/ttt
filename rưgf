// --- HÀM CHẤM ĐIỂM VÀ KIỂM TRA ĐÁP ÁN ---
function submitListeningTest() {
    let totalScore = 0;
    let userCorrectCount = 0;
    const maxScore = listeningQuestionsData.reduce((sum, q) => sum + q.score, 0);

    // Xóa màu cũ nếu có chấm lại
    document.querySelectorAll('.listening-opt-label').forEach(el => {
        el.classList.remove('opt-correct', 'opt-wrong');
    });

    listeningQuestionsData.forEach((q) => {
        const selectedOpt = document.querySelector(`input[name="listening-q-${q.id}"]:checked`);
        const correctLabel = document.getElementById(`label-q-${q.id}-${q.correct}`);
        
        // Luôn tô xanh đáp án đúng để học viên đối chiếu
        if (correctLabel) {
            correctLabel.classList.add('opt-correct');
        }

        if (selectedOpt) {
            const userAns = parseInt(selectedOpt.value);
            if (userAns === q.correct) {
                totalScore += q.score;
                userCorrectCount++;
            } else {
                // Nếu gõ/tích chọn sai thì tô màu đỏ vị trí chọn sai
                const wrongLabel = document.getElementById(`label-q-${q.id}-${userAns}`);
                if (wrongLabel) wrongLabel.classList.add('opt-wrong');
            }
        }
    });

    // Cuộn màn hình lên đầu hoặc vị trí bảng kết quả
    document.getElementById('listening-result-summary').scrollIntoView({ behavior: 'smooth' });

    // Hiển thị bảng tổng kết điểm số
    const resultDiv = document.getElementById('listening-result-summary');
    resultDiv.innerHTML = `
        <div style="background: #e8f4f8; padding: 15px; border-radius: 6px; border: 1px solid #3498db;">
            📊 Kết quả làm bài: Làm đúng <span style="color: #27ae60;">${userCorrectCount}/${listeningQuestionsData.length}</span> câu.<br>
            🎯 Tổng số điểm đạt được: <span style="color: #e74c3c;">${totalScore} điểm</span>.
        </div>
    `;
}
function flipNormalCard(element, event) {
    // Nếu bấm trúng nút ngôi sao hoặc cái loa nhỏ thì không lật thẻ để tránh lỗi cuộn âm thanh
    if (event.target.classList.contains('star-btn') || event.target.closest('.speaker-btn')) {
        return;
    }
    
    let front = element.querySelector('.front-face');
    let back = element.querySelector('.back-face');
    
    if (front && back) {
        if (front.style.display === 'block' || front.style.display === '') {
            front.style.display = 'none';
