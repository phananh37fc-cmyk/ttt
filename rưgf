<script>
// ==========================================
// ĐỘNG CƠ CHẾ ĐỘ HỌC TỪNG THẺ (FOCUS MODE)
// ==========================================
let focusCards = [];
let focusIndex = 0;
let isFocusMode = false;
let isFocusFlipped = false;
let focusAutoPlayTimer = null;
let isAutoPlaying = false;

function startFocusMode() {
    // Lấy nguồn từ vựng từ bộ lọc hiện tại
    let pool = (typeof currentFilteredCards !== 'undefined' && currentFilteredCards.length > 0) ? currentFilteredCards : data;
    if(pool.length === 0) { alert("⚠️ Không có từ vựng nào trong mục này!"); return; }
    
    // Sao chép mảng để không làm hỏng mảng gốc
    focusCards = [...pool];
    focusIndex = 0;
    isFocusMode = true;
    
    // Ẩn giao diện dạng lưới cũ
    document.getElementById('card-container').style.display = 'none';
    let pagination = document.getElementById('pagination-controls');
    if(pagination) pagination.style.display = 'none';
    
    // Hiện giao diện thẻ lớn
    document.getElementById('focus-mode-container').style.display = 'block';
    
    // Cuộn màn hình lên cho đẹp
    document.getElementById('focus-mode-container').scrollIntoView({ behavior: 'smooth', block: 'start' });
    
    renderFocusCard();
}
function shuffleFocusCards() {
    if (focusCards.length <= 1) return; // Không cần xáo nếu chỉ có 1 thẻ
    
    // Tạm dừng tự động phát nếu đang bật
    if (isAutoPlaying) stopAutoPlay();
    
    // Thuật toán xáo trộn mảng ngẫu nhiên
    focusCards.sort(() => Math.random() - 0.5);
    
    // Trả về thẻ đầu tiên của bộ bài mới và vẽ lại
    focusIndex = 0;
    renderFocusCard();
    
    // Hiệu ứng nháy màu nền xanh lá chớp nhoáng để báo hiệu đã xáo trộn thành công
    let cardElement = document.getElementById('focus-card-element');
    let oldColor = cardElement.style.backgroundColor;
    cardElement.style.backgroundColor = '#55efc4'; 
    setTimeout(() => { cardElement.style.backgroundColor = oldColor; }, 300);
}

function toggleFocusLanguage() {
    // Đảo ngược biến cờ hiệu ngôn ngữ chung của toàn app
    if (typeof isReverse !== 'undefined') {
        isReverse = !isReverse;
    } else {
        window.isReverse = true;
    }
    
    // Đồng bộ thay đổi màu sắc với nút "Đảo ngôn ngữ" ở màn hình chính ngoài kia
    let mainRevBtn = document.getElementById('reverse-btn');
    if (mainRevBtn) {
        if(isReverse) {
            mainRevBtn.innerText = "🔄 Mặt trước: Tiếng Hàn";
            mainRevBtn.style.backgroundColor = "#e74c3c";
            mainRevBtn.style.borderColor = "#c0392b";
        } else {
            mainRevBtn.innerText = "🔄 Đảo sang Tiếng Việt";
            mainRevBtn.style.backgroundColor = "#9b59b6";
            mainRevBtn.style.borderColor = "#8e44ad";
        }
    }
    
    // Ép thẻ hiện tại lật về mặt trước và vẽ lại nội dung với ngôn ngữ mới
    isFocusFlipped = false;
    renderFocusCard();
}

function exitFocusMode() {
    isFocusMode = false;
    stopAutoPlay();
    document.getElementById('focus-mode-container').style.display = 'none';
    document.getElementById('card-container').style.display = 'grid'; // Bật lại dạng lưới
    let pagination = document.getElementById('pagination-controls');
    if(pagination) pagination.style.display = 'flex';
}

function renderFocusCard() {
    if(focusCards.length === 0) {
        alert("🎉 Chúc mừng! Bạn đã học thuộc TẤT CẢ từ vựng trong danh sách này!");
        exitFocusMode();
        return;
    }
function flipFocusCard() {
    if (focusCards.length === 0) return; // Nếu không có thẻ nào thì bỏ qua
    
    isFocusFlipped = !isFocusFlipped; // Đảo trạng thái lật thẻ
    
    if (isFocusFlipped) {
        // Lật sang mặt sau
        document.getElementById('focus-front').style.display = 'none';
        document.getElementById('focus-back').style.display = 'block';
    } else {
        // Lật lại mặt trước
        document.getElementById('focus-front').style.display = 'block';
        document.getElementById('focus-back').style.display = 'none';
    }
}
    // Đảm bảo index vòng lặp (Next câu cuối sẽ quay về câu đầu)
    if(focusIndex >= focusCards.length) focusIndex = 0;
    if(focusIndex < 0) focusIndex = focusCards.length - 1;

    let card = focusCards[focusIndex];
    isFocusFlipped = false; // Luôn hiển thị mặt trước khi sang thẻ mới
    
    // Hỗ trợ chế độ Đảo ngôn ngữ Hàn-Việt
    let isRev = typeof isReverse !== 'undefined' && isReverse;
    let frontText = isRev ? card.vn : card.kr;
    let backText = isRev ? card.kr : card.vn;

    // Hiển thị nội dung
    document.getElementById('focus-front').style.display = 'block';
    document.getElementById('focus-back').style.display = 'none';
    document.getElementById('focus-front-text').innerText = frontText;
    document.getElementById('focus-back-text').innerText = backText;
    
    // XỬ LÝ HIỂN THỊ CÂU VÍ DỤ CHUẨN XÁC
    let exBox = document.getElementById('focus-ex-box');
    let exKrElem = document.getElementById('focus-ex-kr');
    let exVnElem = document.getElementById('focus-ex-vn');
    
    if (exBox && exKrElem && exVnElem) {
        if (card.ex_kr || card.ex_vn) {
            exBox.style.display = 'block';
            // Nếu bạn đang bật chế độ đảo mặt (Tiếng Việt ra trước), thì câu ví dụ cũng đảo Tiếng Việt lên trên cho đồng bộ
            exKrElem.innerHTML = isRev ? (card.ex_vn || '') : (card.ex_kr || '');
            exVnElem.innerHTML = isRev ? (card.ex_kr || '') : (card.ex_vn || '');
        } else {
            exBox.style.display = 'none';
        }
    }
    
    // Cập nhật số trang
    document.getElementById('focus-progress').innerText = `${focusIndex + 1} / ${focusCards.length}`;
    
    // Đổi màu nền ngẫu nhiên
    const colors = ['#81ecec', '#fab1a0', '#ffeaa7', '#55efc4', '#74b9ff'];
    document.getElementById('focus-card-element').style.backgroundColor = colors[focusIndex % colors.length];

    // Tự động phát âm thanh tiếng Hàn
    if(!isRev && !isAutoPlaying) speakFocusAudio(null);
}
function nextFocusCard() { focusIndex++; renderFocusCard(); }
function prevFocusCard() { focusIndex--; renderFocusCard(); }
function flipFocusCard() {
    if (focusCards.length === 0) return; // Bỏ qua nếu không có thẻ
    
    isFocusFlipped = !isFocusFlipped; // Đảo trạng thái lật thẻ
    
    if (isFocusFlipped) {
        // Lật sang mặt sau (Tiếng Việt/Đáp án)
        document.getElementById('focus-front').style.display = 'none';
        document.getElementById('focus-back').style.display = 'block';
    } else {
        // Lật lại mặt trước (Tiếng Hàn/Câu hỏi)
        document.getElementById('focus-front').style.display = 'block';
        document.getElementById('focus-back').style.display = 'none';
    }
}
function markFocusCard(isLearned) {
    if (isLearned) {
        // Nếu ĐÃ THUỘC -> Xóa từ này khỏi danh sách đang học để nó không lặp lại nữa
        focusCards.splice(focusIndex, 1);
        renderFocusCard(); // Không cần ++ vì mảng đã bị rút ngắn
    } else {
        // Nếu CHƯA THUỘC -> Bỏ qua, đi tới từ tiếp theo (Nó sẽ quay lại vào vòng sau)
        nextFocusCard();
    }
}

function speakFocusAudio(event) {
    if (event) event.stopPropagation(); // Ngăn việc nhấn nút loa làm lật thẻ
    if (focusCards.length > 0) {
        speakKorean(focusCards[focusIndex].kr, null);
    }
}

// Chế độ tự động phát (Auto-play)
function toggleAutoPlay() {
    isAutoPlaying = !isAutoPlaying;
    let btn = document.getElementById('focus-autoplay-btn');
    
    if (isAutoPlaying) {
        btn.innerHTML = "⏸️ Dừng phát";
        btn.style.background = "#ff7675";
        
        // Cứ mỗi 2.5 giây sẽ thực hiện hành động
        focusAutoPlayTimer = setInterval(() => {
            if (!isFocusFlipped) {
                flipFocusCard(); // Nếu đang mặt trước -> Lật
            } else {
                nextFocusCard(); // Nếu đang mặt sau -> Sang thẻ mới
            }
        }, 2500); 
    } else {
        stopAutoPlay();
        btn.innerHTML = "▶️ Tự động";
        btn.style.background = "#ffeaa7";
    }
}

function stopAutoPlay() {
    isAutoPlaying = false;
    clearInterval(focusAutoPlayTimer);
}

// BẮT SỰ KIỆN PHÍM TẮT TRÊN BÀN PHÍM (Giống hệt Nhaitopik)
document.addEventListener('keydown', function(e) {
    if (!isFocusMode) return;
    
    // Không nhận phím tắt nếu học viên đang gõ chữ ở ô input (nếu có)
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;

    switch(e.code) {
        case 'Space': 
            e.preventDefault(); // Ngăn web cuộn xuống
            flipFocusCard(); 
            break;
        case 'ArrowRight': nextFocusCard(); break;
        case 'ArrowLeft': prevFocusCard(); break;
        case 'ArrowUp': 
            e.preventDefault(); 
            markFocusCard(true); // Đã thuộc
            break; 
        case 'ArrowDown': 
            e.preventDefault(); 
            markFocusCard(false); // Chưa thuộc
            break;
        case 'KeyA': speakFocusAudio(null); break;
        case 'KeyP': toggleAutoPlay(); break;
    }
});
// --- ĐIỀU HƯỚNG CHUYỂN ĐỔI CHẾ ĐỘ GIAO DIỆN ---
function switchMode(mode) {
    const practiceSec = document.querySelector('.container'); // Giữ container từ vựng cũ
    const listeningSec = document.getElementById('listening-test-section');
    const audioPlayer = document.getElementById('topik-audio-player');

    if (mode === 'listening-test') {
        if(practiceSec) practiceSec.style.display = 'none';
        listeningSec.style.display = 'block';
        renderListeningQuestions();
    } else {
        if(listeningSec) listeningSec.style.display = 'none';
        if(practiceSec) practiceSec.style.display = 'block';
        if(audioPlayer) audioPlayer.pause(); // Tắt audio thi nghe khi thoát
    }
}

