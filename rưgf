/* --- CSS CHO NÚT BÔI ĐEN ĐỂ DỊCH --- */
#translate-tooltip {
    position: absolute;
    display: none;
    background-color: #2c3e50;
    color: #ffffff;
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 14px;
    font-weight: bold;
    cursor: pointer;
    z-index: 9999;
    box-shadow: 0 4px 6px rgba(0,0,0,0.3);
    transition: opacity 0.2s;
    pointer-events: none; /* THÊM DÒNG NÀY ĐỂ NÚT DỊCH KHÔNG CHẶN CLICK VÀO THẺ */
}

/* Tạo cái mũi tên nhỏ chỉ xuống dưới nút */
#translate-tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    margin-left: -6px;
    border-width: 6px;
    border-style: solid;
    border-color: #2c3e50 transparent transparent transparent;
}

#translate-tooltip:hover {
    background-color: #1a252f;
}
