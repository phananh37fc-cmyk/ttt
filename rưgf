    if (menu) menu.classList.remove('active');
    if (overlay) overlay.style.display = 'none';
}

// 5. Cắt mảng hiển thị theo từng Trang
function displayPage() {
    let totalPages = Math.ceil(currentFilteredCards.length / itemsPerPage);
    
    // Đảm bảo không bị kẹt ở trang ảo nếu xóa từ cuối cùng của trang
    if (currentPage > totalPages && totalPages > 0) {
        currentPage = totalPages;
    } else if (totalPages === 0) {
        currentPage = 1;
    }

    let start = (currentPage - 1) * itemsPerPage;
    let end = start + itemsPerPage;
    let pageCards = currentFilteredCards.slice(start, end);

    renderCards(pageCards); // Gọi hàm vẽ thẻ
    renderPagination(totalPages); // Gọi hàm vẽ nút chuyển trang
}

// 6. Hiển thị thanh Nút Phân Trang
function renderPagination(totalPages) {
    let paginationDiv = document.getElementById('pagination-controls');
    if (!paginationDiv) return;
    
    if (totalPages <= 1) {
        paginationDiv.style.display = 'none'; // Ẩn nếu chỉ có 1 trang
        return;
    }

    paginationDiv.style.display = 'flex';
    let html = '';

    if (currentPage > 1) {
        html += `<button onclick="changePage(${currentPage - 1})">⬅️ Trang trước</button>`;
    }

    html += `<span style="font-size: 1.1rem; font-weight: bold; color: var(--text-main);">Trang ${currentPage} / ${totalPages}</span>`;

    if (currentPage < totalPages) {
        html += `<button onclick="changePage(${currentPage + 1})">Trang sau ➡️</button>`;
    }

    paginationDiv.innerHTML = html;
}

