    { id: 'v46_sc2_b15', lesson: 'Bài 15', type: 'new', vn: "Tiết kiệm", kr: "아끼다", ex_kr: "돈을 아껴서 저축을 많이 할 생각이에요.", ex_vn: "Tôi định sẽ tiết kiệm tiền để dành dụm nhiều.", note: "" }, //[cite: 2]
    { id: 'v47_sc2_b15', lesson: 'Bài 15', type: 'new', vn: "Chuyển nhà", kr: "이사하다", ex_kr: "다음 주에 학교 근처로 이사할 예정이에요.", ex_vn: "Tuần sau tôi dự định sẽ chuyển nhà đến gần trường.", note: "" }, //[cite: 2]
    { id: 'v48_sc2_b15', lesson: 'Bài 15', type: 'new', vn: "Diễn ra tốt đẹp", kr: "잘되다", ex_kr: "열심히 노력한 덕분에 시험이 잘되었어요.", ex_vn: "Nhờ nỗ lực chăm chỉ nên kỳ thi đã diễn ra tốt đẹp.", note: "" }, //[cite: 2]
    { id: 'v49_sc2_b15', lesson: 'Bài 15', type: 'new', vn: "Ồn ào", kr: "시끄럽다", ex_kr: "옆집 강아지가 너무 시끄럽게 짖어요.", ex_vn: "Chó con nhà bên sủa ồn ào quá.", note: "" }, //[cite: 2]
    { id: 'v50_sc2_b15', lesson: 'Bài 15', type: 'new', vn: "Yên tĩnh", kr: "조용하다", ex_kr: "도서관 안에서는 항상 조용해야 해요.", ex_vn: "Ở trong thư viện phải luôn luôn yên tĩnh.", note: "" }, //[cite: 2]
    { id: 'v51_sc2_b15', lesson: 'Bài 15', type: 'new', vn: "Liệu, có lẽ, hay là", kr: "혹시", ex_kr: "혹시 시간이 있으면 커피 한잔 할까요?", ex_vn: "Liệu bạn có thời gian không, chúng ta cùng uống ly cà phê nhé?", note: "" }, //[cite: 2]
    { id: 'v52_sc2_b15', lesson: 'Bài 15', type: 'new', vn: "Đăng ký", kr: "신청하다", ex_kr: "한국어 말하기 대회에 참가 신청을 했어요.", ex_vn: "Tôi đã đăng ký tham gia cuộc thi nói tiếng Hàn.", note: "" }, //[cite: 2]
    { id: 'v53_sc2_b15', lesson: 'Bài 15', type: 'new', vn: "Hộ chiếu", kr: "여권", ex_kr: "외국에 갈 때는 여권이 꼭 필요합니다.", ex_vn: "Khi đi ra nước ngoài thì nhất định cần phải có hộ chiếu.", note: "" }, //[cite: 2]
    { id: 'v54_sc2_b15', lesson: 'Bài 15', type: 'new', vn: "Máy giặt", kr: "세탁기", ex_kr: "세탁기가 고장 나서 손빨래를 했어요.", ex_vn: "Máy giặt bị hỏng nên tôi đã giặt bằng tay.", note: "" }, //[cite: 2]
    { id: 'v55_sc2_b15', lesson: 'Bài 15', type: 'new', vn: "Tủ lạnh", kr: "냉장고", ex_kr: "우유를 사서 냉장고에 넣었어요.", ex_vn: "Tôi mua sữa rồi bỏ vào tủ lạnh.", note: "" }, //[cite: 2]
    { id: 'v56_sc2_b15', lesson: 'Bài 15', type: 'new', vn: "Nhẫn", kr: "반지", ex_kr: "남자친구에게 금반지를 선물 받았어요.", ex_vn: "Tôi nhận được món quà là nhẫn vàng từ bạn trai.", note: "" }, //[cite: 2]
    { id: 'v57_sc2_b15', lesson: 'Bài 15', type: 'new', vn: "Socola", kr: "초콜릿", ex_kr: "피곤할 때 달콤한 초콜릿을 먹으면 힘이 나요.", ex_vn: "Khi mệt mỏi ăn socola ngọt vào thì sẽ có sức.", note: "" }, //[cite: 2]
    { id: 'v58_sc2_b15', lesson: 'Bài 15', type: 'new', vn: "Khăn tay", kr: "손수건", ex_kr: "땀이 날 때 손수건으로 얼굴을 닦아요.", ex_vn: "Khi đổ mồ hôi tôi lấy khăn tay lau mặt.", note: "" }, //[cite: 2]
    { id: 'v59_sc2_b15', lesson: 'Bài 15', type: 'new', vn: "Quảng cáo, quảng bá", kr: "광고", ex_kr: "텔레비전에서 재미있는 화장품 광고를 봤어요.", ex_vn: "Tôi đã xem một quảng cáo mỹ phẩm thú vị trên tivi.", note: "" }, //[cite: 2]
    { id: 'v60_sc2_b15', lesson: 'Bài 15', type: 'new', vn: "Bảng thông báo", kr: "게시판", ex_kr: "학교 게시판에서 시험 날짜를 확인했어요.", ex_vn: "Tôi đã xác nhận ngày thi ở bảng thông báo của trường.", note: "" }, //[cite: 2]
    // --- NHÓM 1: NGUYÊN NHÂN, LÝ DO (VÌ... NÊN) ---
    { id: 'g1_sc2', lesson: 'Nhóm 1: Lý do', type: 'grammar', kr: "V/A-아/어서", vn: "Vì... nên...", note: "1. Không dùng cho câu mệnh lệnh, rủ rê (-(으)세요, -(으)ㅂ시다). \n2. Không chia thì quá khứ/tương lai (-았/었/겠-) ở vế trước. \n3. Thường dùng cho lý do khách quan, lời xin lỗi/cảm ơn (늦어서 죄송합니다)." },
    { id: 'g2_sc2', lesson: 'Nhóm 1: Lý do', type: 'grammar', kr: "V/A-(으)니까", vn: "Vì... nên...", note: "1. Được phép đi kèm câu mệnh lệnh, rủ rê. \n2. Được phép chia thì quá khứ/tương lai ở vế trước (비가 왔으니까 우산을 쓰세요). \n3. Với Danh từ: N(이)니까. Nhấn mạnh lý do chủ quan của người nói." },
    { id: 'g3_sc2', lesson: 'Nhóm 1: Lý do', type: 'grammar', kr: "V/A-기 때문에", vn: "Bởi vì, do...", note: "Mức độ nhấn mạnh lý do mạnh hơn 아/어서. Nếu kết hợp với Danh từ thì không cần 기, chỉ cần dùng: N + 때문에 (Ví dụ: 비 때문에 - vì mưa)." },
    { id: 'g4_sc2', lesson: 'Nhóm 1: Lý do', type: 'grammar', kr: "N(이)라서", vn: "Vì là N nên...", note: "Cấu trúc chuyên dùng cho Danh từ. Nếu N có patchim + 이라서, không có patchim + 라서 (Ví dụ: 학생이라서 돈이 없어요 - Vì là học sinh nên không có tiền)." },

    // --- NHÓM 2: MỤC ĐÍCH, Ý ĐỊNH, KẾ HOẠCH (ĐỂ, ĐỊNH) ---
    { id: 'g5_sc2', lesson: 'Nhóm 2: Mục đích', type: 'grammar', kr: "V-(으)려고", vn: "Để...", note: "Chỉ mục đích hành động. Thường theo sau là các động từ chuyển động hoặc hành động cụ thể để đạt được vế trước." },
    { id: 'g6_sc2', lesson: 'Nhóm 2: Mục đích', type: 'grammar', kr: "V-기 위해서 / N을/를 위해서", vn: "Để, vì...", note: "Mang sắc thái trang trọng hơn -(으)려고. Ưu điểm là có thể kết hợp trực tiếp với Danh từ (Ví dụ: 건강을 위해서 - Vì sức khỏe)." },
    { id: 'g7_sc2', lesson: 'Nhóm 2: Kế hoạch', type: 'grammar', kr: "V-(으)려고 하다", vn: "Định làm gì...", note: "Nêu lên ý định, kế hoạch đã được suy nghĩ từ trước nhưng chưa thực sự bắt đầu làm." },
    { id: 'g8_sc2', lesson: 'Nhóm 2: Kế hoạch', type: 'grammar', kr: "V-(으)ㄹ까 하다", vn: "Tính là, định là...", note: "Ý định này mang tính chất phân vân, chưa chắc chắn bằng -(으)려고 하다 (Đang tính làm nhưng có thể thay đổi)." },
    { id: 'g9_sc2', lesson: 'Nhóm 2: Kế hoạch', type: 'grammar', kr: "V-기로 하다", vn: "Quyết định làm gì", note: "Thường dùng ở thì quá khứ: -기로 했다 (Tôi ĐÃ quyết định làm việc đó). Thể hiện sự hứa hẹn, cam kết với bản thân hoặc người khác." },

    // --- NHÓM 3: TƯƠNG PHẢN, BỐI CẢNH (NHƯNG, THÌ) ---
    { id: 'g10_sc2', lesson: 'Nhóm 3: Tương phản', type: 'grammar', kr: "V/A-지만", vn: "Tuy... nhưng", note: "Nối 2 vế đối lập rõ ràng. Có thể chia thì ở vế trước (먹었지만 - Đã ăn nhưng...)." },
    { id: 'g11_sc2', lesson: 'Nhóm 3: Bối cảnh', type: 'grammar', kr: "A-(으)ㄴ데 / V-는데 / N인데", vn: "Nhưng mà, và, thì...", note: "RẤT QUAN TRỌNG: \n- Động từ: + 는데\n- Tính từ: có patchim + 은데 / không patchim + ㄴ데\n- Danh từ: + 인데\nDùng để đưa ra bối cảnh (hoàn cảnh) trước khi giải thích, hỏi hoặc đề nghị ở vế sau." },

    // --- NHÓM 4: ĐIỀU KIỆN, GIẢ ĐỊNH (NẾU... THÌ) ---
    { id: 'g12_sc2', lesson: 'Nhóm 4: Điều kiện', type: 'grammar', kr: "V/A-(으)면", vn: "Nếu... thì...", note: "Có patchim + 으면, không có patchim + 면. Đưa ra điều kiện hoặc một giả định chung." },
    { id: 'g13_sc2', lesson: 'Nhóm 4: Điều kiện', type: 'grammar', kr: "V-(으)려면", vn: "Nếu muốn... thì phải...", note: "Là dạng rút gọn của '려고 하면'. Nếu có ý định làm gì đó ở vế trước, thì vế sau thường là câu khuyên bảo (hãy, phải, nên làm gì)." },

    // --- NHÓM 5: THỜI GIAN, TRÌNH TỰ ---
    { id: 'g14_sc2', lesson: 'Nhóm 5: Thời gian', type: 'grammar', kr: "N부터 ~ N까지", vn: "Từ... đến...", note: "Đánh dấu điểm khởi đầu và kết thúc của thời gian hoặc địa điểm." },
    { id: 'g15_sc2', lesson: 'Nhóm 5: Thời gian', type: 'grammar', kr: "V/A-(으)ㄹ 때", vn: "Khi, lúc...", note: "Chỉ thời điểm xảy ra sự việc. Với Danh từ thì ghép thẳng: N 때 (Ví dụ: 방학 때 - Lúc nghỉ hè)." },
    { id: 'g16_sc2', lesson: 'Nhóm 5: Thời gian', type: 'grammar', kr: "N 동안 / V-는 동안", vn: "Trong lúc, trong khoảng...", note: "Diễn tả khoảng thời gian hành động kéo dài. (Ví dụ: 3일 동안 - Trong vòng 3 ngày / 밥을 먹는 동안 - Trong lúc ăn cơm)." },
    { id: 'g17_sc2', lesson: 'Nhóm 5: Thời gian', type: 'grammar', kr: "V-(으)면서", vn: "Vừa... vừa...", note: "Hai hành động do CÙNG MỘT NGƯỜI thực hiện đồng thời. (Ví dụ: 음악을 들으면서 공부해요)." },
    { id: 'g18_sc2', lesson: 'Nhóm 5: Trình tự', type: 'grammar', kr: "V-기 전에", vn: "Trước khi...", note: "Luôn dùng dạng nguyên mẫu + 기 전에. Với Danh từ: N 전에." },
    { id: 'g19_sc2', lesson: 'Nhóm 5: Trình tự', type: 'grammar', kr: "V-(으)ㄴ 후에", vn: "Sau khi...", note: "Hành động trước phải dùng định ngữ quá khứ. Với Danh từ: N 후에." },
    { id: 'g20_sc2', lesson: 'Nhóm 5: Trình tự', type: 'grammar', kr: "V-고 나서", vn: "Sau khi (xong)...", note: "Nhấn mạnh hành động thứ nhất phải được HOÀN TẤT TRỌN VẸN rồi mới đến hành động thứ 2." },

    // --- NHÓM 6: KHẢ NĂNG, KINH NGHIỆM ---
    { id: 'g21_sc2', lesson: 'Nhóm 6: Khả năng', type: 'grammar', kr: "V-(으)ㄹ 수 있다/없다", vn: "Có thể / Không thể...", note: "Chỉ khả năng hoặc năng lực làm một việc gì đó." },
    { id: 'g22_sc2', lesson: 'Nhóm 6: Khả năng', type: 'grammar', kr: "V-(으)ㄹ 줄 알다/모르다", vn: "Biết cách / Không biết cách...", note: "Khác với 수 있다 (khả năng nói chung), ngữ pháp này tập trung vào việc có 'phương pháp/kỹ năng' hay không (Ví dụ: Bạn có biết cách bơi không?)." },
    { id: 'g23_sc2', lesson: 'Nhóm 6: Kinh nghiệm', type: 'grammar', kr: "V-아/어 보다", vn: "Thử làm gì / Từng làm gì", note: "Khuyên ai đó thử làm gì (먹어 보세요 - Hãy ăn thử đi) hoặc kể lại kinh nghiệm đã từng trải qua." },
    { id: 'g24_sc2', lesson: 'Nhóm 6: Kinh nghiệm', type: 'grammar', kr: "V-(으)ㄴ 적이 있다/없다", vn: "Đã từng / Chưa từng...", note: "Dùng để kể lại một sự việc/kinh nghiệm đã hoặc chưa từng xảy ra trong quá khứ. Rất hay đi cùng V-아/어 본 적이 있다 (Đã từng thử...)." },

    // --- NHÓM 7: RỦ RÊ, ĐỀ NGHỊ, HỨA HẸN ---
    { id: 'g25_sc2', lesson: 'Nhóm 7: Rủ rê', type: 'grammar', kr: "V-(으)ㅂ시다 / V-지 맙시다", vn: "Hãy cùng... / Đừng cùng...", note: "Dùng cho quan hệ ngang hàng hoặc người nhỏ tuổi hơn. KHÔNG dùng cho người bề trên." },
    { id: 'g26_sc2', lesson: 'Nhóm 7: Đề nghị', type: 'grammar', kr: "V/A-(으)ㄹ까요?", vn: "Nhé? Nhỉ? / Có lẽ... không?", note: "Hỏi ý kiến đối phương (우리 영화 볼까요? - Tụi mình xem phim nhé?) hoặc tự đưa ra câu hỏi suy đoán (내일 비가 올까요? - Mai liệu có mưa không nhỉ?)." },
    { id: 'g27_sc2', lesson: 'Nhóm 7: Đề nghị', type: 'grammar', kr: "V-(으)ㄹ래요?", vn: "Bạn muốn... chứ?", note: "Hỏi ý muốn của người nghe một cách nhẹ nhàng, thân mật. Người trả lời cũng có thể dùng: V-(으)ㄹ래요 (Tôi muốn... / Tôi sẽ...)." },
    { id: 'g28_sc2', lesson: 'Nhóm 7: Kính trọng', type: 'grammar', kr: "V-(으)시겠습니까? / (으)시겠어요?", vn: "Sẽ... chứ ạ? (Kính trọng)", note: "Dùng khi phục vụ khách hàng hoặc đối thoại với người lớn tuổi/cấp trên (주문하시겠습니까? - Quý khách muốn gọi món chưa ạ?)." },
    { id: 'g29_sc2', lesson: 'Nhóm 7: Hứa hẹn', type: 'grammar', kr: "V-(으)ㄹ게요", vn: "Tôi sẽ...", note: "Người nói tự hứa hẹn/cam kết thực hiện hành động. CHỈ dùng cho ngôi thứ nhất (Tôi/Mình)." },

    // --- NHÓM 8: NGHĨA VỤ, CHO PHÉP, CẤM ĐOÁN ---
    { id: 'g30_sc2', lesson: 'Nhóm 8: Nghĩa vụ', type: 'grammar', kr: "V/A-아/어야 되다/하다", vn: "Phải làm gì...", note: "Bắt buộc thực hiện. '하다' mang tính văn viết/trang trọng hơn một chút so với '되다' (thường dùng trong văn nói)." },
    { id: 'g31_sc2', lesson: 'Nhóm 8: Cho phép', type: 'grammar', kr: "V-아/어도 되다", vn: "Được phép làm... / Làm... cũng được", note: "Sự cho phép. Câu hỏi: V-아/어도 돼요? (Tôi làm thế này có được không?)." },
    { id: 'g32_sc2', lesson: 'Nhóm 8: Cấm đoán', type: 'grammar', kr: "V-(으)면 안 되다", vn: "Không được làm...", note: "Khuyên bảo hoặc ngăn cấm. Có patchim + 으면 안 되다, không có + 면 안 되다." },

    // --- NHÓM 9: TRẠNG THÁI, SỰ BIẾN ĐỔI ---
    { id: 'g33_sc2', lesson: 'Nhóm 9: Trạng thái', type: 'grammar', kr: "V-고 있다", vn: "Đang...", note: "Hành động đang diễn ra tại thời điểm nói. (Ví dụ: 밥을 먹고 있어요 - Đang ăn cơm)." },
    { id: 'g34_sc2', lesson: 'Nhóm 9: Trạng thái', type: 'grammar', kr: "V-아/어 있다", vn: "Đang (duy trì trạng thái)", note: "Hành động ĐÃ hoàn tất nhưng TRẠNG THÁI vẫn đang được duy trì (Chỉ đi với tự động từ). Ví dụ: 앉아 있다 (Đang ngồi), 문이 열려 있다 (Cửa đang mở)." },
    { id: 'g35_sc2', lesson: 'Nhóm 9: Biến đổi', type: 'grammar', kr: "A-아/어지다", vn: "Trở nên...", note: "Chỉ đi với TÍNH TỪ. Diễn tả sự thay đổi trạng thái theo thời gian. (Ví dụ: 날씨가 추워졌어요 - Thời tiết đã trở nên lạnh hơn)." },
    { id: 'g36_sc2', lesson: 'Nhóm 9: Biến đổi', type: 'grammar', kr: "V-게 되다", vn: "Bị, được, trở nên...", note: "Đi với ĐỘNG TỪ. Sự việc thay đổi do một yếu tố/tác động khách quan mang lại, không phải do cố ý từ đầu." },
