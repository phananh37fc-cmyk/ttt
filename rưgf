let masterAudioPlayer = null;

// Hàm kích hoạt nạp file âm thanh từ thiết bị vào bảng điều khiển trung tâm
function loadAudioFile(input) {
    if (input.files && input.files[0]) {
        const file = input.files[0];
        const fileURL = URL.createObjectURL(file);
        
        masterAudioPlayer = document.getElementById('master-topik-audio');
        masterAudioPlayer.src = fileURL;
        
        // Hiển thị thanh phát trung tâm lên
        document.getElementById('master-audio-box').style.display = 'block';
        alert("🎯 Đã đồng bộ file âm thanh! Bây giờ bạn chỉ cần bấm nút nghe ở từng câu hỏi.");
        renderListeningQuestions();
    }
}

// Hàm ra lệnh nhảy đến số giây chính xác của câu hỏi và phát nhạc
function jumpToTimeAndPlay(seconds, questionId) {
    if (!masterAudioPlayer) {
        alert("⚠️ Vui lòng bấm nút 'Chọn file' ở trên đầu trang trước khi nghe!");
        return;
    }
    
    // Thực hiện nhảy thời gian (tời câu) tự động
    masterAudioPlayer.currentTime = seconds;
    masterAudioPlayer.play();
    
    // Cập nhật trạng thái thông báo cho học viên dễ nhìn
    const minutes = Math.floor(seconds / 60);
    const remainingSeconds = seconds % 60;
    const timeString = `${minutes}:${remainingSeconds < 10 ? '0' : ''}${remainingSeconds}`;
    document.getElementById('audio-status-tip').innerHTML = `🔥 Đang phát <b>Câu ${questionId}</b> (Bắt đầu tại mốc thời gian: <span style="color:#e74c3c;">${timeString}</span>)`;
}

